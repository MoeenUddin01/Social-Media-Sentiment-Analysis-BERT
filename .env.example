# Environment variables for BERT sentiment analysis project
# Copy this file to .env and fill in your actual values

# DagsHub MLflow tracking credentials
DAGSHUB_TOKEN=your_token_here
MLFLOW_TRACKING_USERNAME=your_dagshub_username
MLFLOW_TRACKING_PASSWORD=your_dagshub_token

# Weights & Biases API key for experiment tracking
WANDB_API_KEY=your_wandb_api_key_here

# Twitter API credentials (for data collection)
TWITTER_BEARER_TOKEN=your_twitter_bearer_token_here
TWITTER_API_KEY=your_twitter_api_key_here
TWITTER_API_SECRET=your_twitter_api_secret_here
TWITTER_ACCESS_TOKEN=your_twitter_access_token_here
TWITTER_ACCESS_TOKEN_SECRET=your_twitter_access_token_secret_here

# HuggingFace Hub token (for model upload/download)
HF_TOKEN=your_huggingface_token_here

# Model paths
MODEL_CHECKPOINT_DIR=src/models/checkpoints
DATA_RAW_DIR=src/data/raw
DATA_PROCESSED_DIR=src/data/processed

# Training configuration
CUDA_VISIBLE_DEVICES=0
PYTHONPATH=.
